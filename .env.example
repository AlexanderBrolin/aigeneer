# LLM (AITUNNEL — OpenAI-compatible proxy)
AITUNNEL_BASE_URL=https://api.aitunnel.ru/v1/
AITUNNEL_API_KEY=sk-aitunnel-xxx
MODEL_MAIN=claude-sonnet-4.6
MODEL_FAST=claude-haiku-4-5

# Telegram
TG_BOT_TOKEN=...
TG_ALLOWED_USERS=123456789
TG_CHAT_ID=...

# Database (MariaDB)
DATABASE_URL=mysql+aiomysql://opsagent:changeme@db:3306/opsagent
DB_ROOT_PASSWORD=rootchangeme
DB_NAME=opsagent
DB_USER=opsagent
DB_PASSWORD=changeme

# Redis (redis-stack for LangGraph checkpoints)
REDIS_URL=redis://redis:6379/0

# Web panel
SECRET_KEY=change-me-to-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# SSH defaults (can be overridden per-server in web panel)
SSH_DEFAULT_KEY_PATH=~/.ssh/id_rsa
SSH_DEFAULT_USER=deploy

# Schedule
CHECK_INTERVAL_MINUTES=5
